# Discord bot token — from https://discord.com/developers/applications
DISCORD_TOKEN=

# Your bot's application ID
CLIENT_ID=

# The server (guild) ID where commands are registered
GUILD_ID=

# The ID of the role to assign to active players (2 of last 3 events)
# Create this role manually in Discord first, then paste its ID here
# The bot's role must be ranked ABOVE this role in the server's role list
ATTENDANCE_ROLE_ID=

# Channel where tournament standings are posted after each /upload
RESULTS_CHANNEL_ID=
