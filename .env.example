# Discord bot token — from https://discord.com/developers/applications
DISCORD_TOKEN=

# Your bot's application ID
CLIENT_ID=

# The server (guild) ID where commands are registered
GUILD_ID=

# MariaDB connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=tcgbot
DB_PASSWORD=
DB_NAME=tcgbot

# The ID of the role to assign to active players (2 of last 3 events)
# Create this role manually in Discord first, then paste its ID here
# The bot's role must be ranked ABOVE this role in the server's role list
ATTENDANCE_ROLE_ID=

# Channel where tournament standings are posted after each /upload
RESULTS_CHANNEL_ID=

# Channel where new upcoming events are posted automatically
EVENTS_CHANNEL_ID=

# Location for event polling (from pokedata.ovh)
# Find your coordinates on Google Maps — right-click → copy coordinates
POKEMON_EVENT_LAT=
POKEMON_EVENT_LON=
POKEMON_EVENT_RADIUS=10
POKEMON_EVENT_COUNTRY=BE

# IANA timezone for event times (default: Europe/Brussels)
POKEMON_EVENT_TIMEZONE=Europe/Brussels
